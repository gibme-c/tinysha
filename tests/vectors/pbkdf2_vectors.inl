// PBKDF2-HMAC test vectors
// SHA-256: from draft-josefsson-scrypt-kdf section 11
// SHA-384/512/SHA3-*: computed with Python hashlib
#pragma once

#include <cstddef>
#include <cstdint>

struct PBKDF2Vector
{
    const uint8_t *password;
    size_t password_len;
    const uint8_t *salt;
    size_t salt_len;
    uint32_t iterations;
    size_t dk_len;
    const uint8_t *expected;
    size_t expected_len;
};

